JWT_SECRET="replace-with-a-long-random-secret"

## SEC-301: SSN encryption at rest
# 32-byte key encoded as base64 (recommended) or 64-char hex.
# Example (base64): node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SSN_ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_BASE64_KEY"

